	"dependencies": {
		"@homepage/env": "workspace:*",
		"@once-ui-system/core": "^1.7.9",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@homepage/config": "workspace:*",
		"@types/bun": "catalog:",
		"lefthook": "^2.1.9",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.9"
